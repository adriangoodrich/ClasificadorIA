<Window x:Class="ClasificadorIA.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clasificador IA de Archivos" 
        Height="750" 
        Width="950"
        MinHeight="500" 
        MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Título con selector de idioma (solo aquí) -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#2C3E50" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                    <TextBlock x:Name="TituloPrincipal" Text="📁 CLASIFICADOR IA DE ARCHIVOS" 
                               FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                </Border>
                <!-- Selector de idioma -->
                <ComboBox Grid.Column="1" x:Name="ComboIdioma" Width="120" Height="35" 
                          SelectionChanged="ComboIdioma_SelectionChanged"
                          Background="White" BorderBrush="#BDC3C7" Margin="0,0,0,0">
                    <ComboBoxItem Tag="es" IsSelected="True">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🇪🇸 " FontSize="18"/>
                            <TextBlock Text="Español" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ComboBoxItem>
                    <ComboBoxItem Tag="en">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🇺🇸 " FontSize="18"/>
                            <TextBlock Text="English" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ComboBoxItem>
                </ComboBox>
            </Grid>

            <!-- Seleccionar carpeta -->
            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderBrush="#BDC3C7" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="LblSeleccionarCarpeta" Text="📂 1. SELECCIONAR CARPETA" 
                               FontSize="14" FontWeight="Bold" Margin="0,0,0,8" Foreground="#2C3E50"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="📁" FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="TxtRuta" IsReadOnly="True" Padding="8" Background="#F8F9F9" 
                                 Text="Ninguna carpeta seleccionada" TextWrapping="Wrap"/>
                        <Button Grid.Column="2" x:Name="BtnExaminar" Content="Examinar" Padding="15,8" Margin="8,0,0,0" 
                                Click="BtnExaminar_Click" Background="#27AE60" Foreground="White" 
                                BorderThickness="0" Cursor="Hand"/>
                    </Grid>
                    <TextBlock x:Name="TxtArchivos" Margin="0,8,0,0" Foreground="#7F8C8D" 
                               Text="0 archivos encontrados"/>
                </StackPanel>
            </Border>

            <!-- Modo, Criterio y Profundidad en una sola línea -->
            <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderBrush="#BDC3C7" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="LblModo" Text="🎯 MODO" FontSize="13" FontWeight="Bold" Margin="0,0,0,5" Foreground="#2C3E50"/>
                        <ComboBox x:Name="ComboModo" SelectionChanged="ComboModo_SelectionChanged" Height="30"/>
                    </StackPanel>
                    <Grid Grid.Column="1">
                        <Rectangle Fill="#BDC3C7" Width="1" HorizontalAlignment="Center"/>
                    </Grid>

                    <StackPanel Grid.Column="2">
                        <TextBlock x:Name="LblCriterio" Text="🔍 CRITERIO" FontSize="13" FontWeight="Bold" Margin="0,0,0,5" Foreground="#2C3E50"/>
                        <ComboBox x:Name="ComboCriterio" SelectionChanged="ComboCriterio_SelectionChanged" Height="30"/>
                    </StackPanel>
                    <Grid Grid.Column="3">
                        <Rectangle Fill="#BDC3C7" Width="1" HorizontalAlignment="Center"/>
                    </Grid>

                    <StackPanel Grid.Column="4">
                        <TextBlock x:Name="LblProfundidad" Text="🎚️ PROFUNDIDAD" FontSize="13" FontWeight="Bold" Margin="0,0,0,5" Foreground="#2C3E50"/>
                        <ComboBox x:Name="ComboProfundidad" SelectionChanged="ComboProfundidad_SelectionChanged" Height="30">
                            <ComboBoxItem Content="5 categorías" Tag="5"/>
                            <ComboBoxItem Content="10 categorías" Tag="10"/>
                            <ComboBoxItem Content="15 categorías" Tag="15"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Prompt -->
            <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderBrush="#BDC3C7" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="LblPrompt" Text="🤖 4. PROMPT PARA IA" FontSize="14" FontWeight="Bold" Margin="0,0,0,8" Foreground="#2C3E50"/>
                    <TextBox Grid.Row="1" x:Name="TxtPromptPreview" TextWrapping="Wrap" IsReadOnly="True" Background="#F0F0F0" 
                             Padding="6" FontFamily="Consolas" FontSize="11" MaxHeight="120" VerticalScrollBarVisibility="Auto"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button x:Name="BtnCopiarPrompt" Content="📋 Copiar" Padding="12,6" Margin="0,0,5,0" 
                                Click="BtnCopiarPrompt_Click" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        <Button x:Name="BtnGuardarPrompt" Content="💾 Guardar" Padding="12,6" Margin="5,0,0,0" 
                                Click="BtnGuardarPrompt_Click" Background="#F39C12" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Resultados -->
            <Border Grid.Row="4" Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderBrush="#BDC3C7" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="LblRespuesta" Text="📥 5. RESPUESTA DE LA IA (categorías)" FontSize="14" FontWeight="Bold" Margin="0,0,0,8" Foreground="#2C3E50"/>

                    <ScrollViewer Grid.Row="1" 
                                  VerticalScrollBarVisibility="Auto" 
                                  HorizontalScrollBarVisibility="Disabled"
                                  Background="#FAFAFA" 
                                  BorderThickness="1" 
                                  BorderBrush="#DDD" 
                                  Padding="5"
                                  MaxHeight="300">
                        <StackPanel x:Name="PanelCategorias" Margin="0,0,0,5"/>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button x:Name="BtnCargar" Content="📂 Cargar" Padding="12,6" Margin="0,0,5,0" 
                                Click="BtnCargarRespuesta_Click" Background="#E67E22" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        <Button x:Name="BtnPegar" Content="📋 Pegar" Padding="12,6" Margin="5,0,0,0" 
                                Click="BtnPegarRespuesta_Click" Background="#9B59B6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Acciones finales -->
            <Border Grid.Row="5" Background="White" CornerRadius="8" Padding="12" BorderBrush="#BDC3C7" BorderThickness="1">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <RadioButton x:Name="RbCopiar" Content="📋 Copiar archivos" IsChecked="True" Margin="0,0,25,0"/>
                        <RadioButton x:Name="RbMover" Content="✂️ Mover archivos"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="BtnIniciar" Content="🚀 INICIAR" Padding="30,12" Margin="5" 
                                Click="BtnIniciar_Click" Background="#27AE60" Foreground="White" 
                                FontWeight="Bold" FontSize="14" BorderThickness="0" IsEnabled="False" Cursor="Hand"/>
                        <Button x:Name="BtnCancelar" Content="❌ CANCELAR" Padding="30,12" Margin="5" 
                                Click="BtnCancelar_Click" Background="#E74C3C" Foreground="White" 
                                FontWeight="Bold" FontSize="14" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                    <ProgressBar x:Name="ProgressBar" Height="4" Margin="0,10,0,0" Visibility="Collapsed" Foreground="#3498DB" IsIndeterminate="True"/>
                    <TextBlock x:Name="TxtProgreso" HorizontalAlignment="Center" Margin="8" Foreground="#7F8C8D" Visibility="Collapsed"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>