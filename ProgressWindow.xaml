<Window x:Class="ClasificadorIA.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Progreso"
        Height="180"
        Width="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<TextBlock x:Name="TxtMensaje" Grid.Row="0" Text="Procesando archivos..." FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15" HorizontalAlignment="Center"/>

		<ProgressBar Grid.Row="1" x:Name="ProgressBar" Height="25" Minimum="0" Maximum="100" Value="0" Margin="0,0,0,15"/>

		<StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
			<Button x:Name="BtnCancelar" Content="Cancelar" Padding="20,8" Click="BtnCancelar_Click" Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
		</StackPanel>
	</Grid>
</Window>